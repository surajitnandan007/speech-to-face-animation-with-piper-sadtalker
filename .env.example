# Optional: override where the SadTalker repo lives inside the container.
SADTALKER_REPO_PATH=/opt/SadTalker

# Optional: leave as "python" when SadTalker runs in the same environment.
SADTALKER_PYTHON_EXECUTABLE=python

# Optional: baked-in checkpoints path. Leave blank to use SadTalker's default.
SADTALKER_CHECKPOINT_DIR=/opt/models/checkpoints

# Optional: default source image if callers only upload audio.
DEFAULT_SOURCE_IMAGE=

# Piper voice settings for text-to-speech requests.
PIPER_VOICE=en_US-lessac-medium
PIPER_DATA_DIR=/opt/piper/data
PIPER_DOWNLOAD_DIR=/opt/piper/downloads

UPLOAD_DIR=/app/storage/uploads
RESULTS_DIR=/app/storage/results
